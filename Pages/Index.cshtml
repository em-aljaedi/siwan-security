@page
@model siwan1.Pages.IndexModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منصة صِوان | الحماية السيادية للمستندات</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
            /* الألوان الأساسية والهوية البصرية المستوحاة من الشعار */
            :root {
                --bg-deep-blue: #0B132B;
                --card-blue: #1C2541;
                --cyber-cyan: #00B4D8;
                --text-light: #E0FBFC;
                --error-red: #EF4444;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
                font-family: 'Noto Sans Arabic', sans-serif;
            }

            body {
                background-color: var(--bg-deep-blue);
                color: #FFFFFF;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            /* شريط التنقل العلوي (Header) */
            header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 20px 80px;
                background-color: rgba(28, 37, 65, 0.5);
                border-bottom: 1px solid rgba(0, 180, 216, 0.2);
            }

            .logo {
                font-size: 28px;
                font-weight: bold;
                color: var(--cyber-cyan);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .nav-tabs button {
                background: none;
                border: none;
                color: var(--text-light);
                font-size: 18px;
                font-weight: bold;
                margin-right: 20px;
                cursor: pointer;
                padding: 10px 20px;
                border-radius: 20px;
                transition: 0.3s;
            }

                .nav-tabs button.active {
                    background-color: var(--cyber-cyan);
                    color: var(--bg-deep-blue);
                }

            /* تقسيم الشاشة إلى عمودين (Layout) */
            .main-container {
                flex-grow: 1;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 60px;
                padding: 60px 80px;
                align-items: center;
            }

            .info-section h1 {
                font-size: 48px;
                color: #FFFFFF;
                margin-bottom: 20px;
                line-height: 1.4;
            }

                .info-section h1 span {
                    color: var(--cyber-cyan);
                }

            .info-section p {
                font-size: 20px;
                color: var(--text-light);
                line-height: 1.8;
                margin-bottom: 30px;
            }

            .feature-badge {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                background: rgba(0, 180, 216, 0.1);
                border: 1px solid var(--cyber-cyan);
                padding: 8px 16px;
                border-radius: 20px;
                color: var(--cyber-cyan);
                font-weight: bold;
            }

            .vault-card {
                background-color: var(--card-blue);
                border-radius: 24px;
                padding: 40px;
                border: 1px solid rgba(255, 255, 255, 0.05);
                box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            }

            .drop-zone {
                border: 2px dashed var(--cyber-cyan);
                border-radius: 16px;
                padding: 40px 20px;
                text-align: center;
                cursor: pointer;
                background: rgba(0, 180, 216, 0.02);
                transition: 0.3s;
                margin-bottom: 25px;
            }

                .drop-zone:hover {
                    background: rgba(0, 180, 216, 0.08);
                }

                .drop-zone i {
                    font-size: 48px;
                    color: var(--cyber-cyan);
                    margin-bottom: 15px;
                }

                .drop-zone p {
                    color: var(--text-light);
                    font-size: 16px;
                }

            .input-group {
                margin-bottom: 20px;
            }

                .input-group label {
                    display: block;
                    margin-bottom: 8px;
                    color: var(--text-light);
                    font-size: 15px;
                    text-align: right;
                }

                .input-group input {
                    width: 100%;
                    padding: 14px;
                    background-color: var(--bg-deep-blue);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                    border-radius: 10px;
                    color: #FFFFFF;
                    font-size: 16px;
                    outline: none;
                    transition: 0.3s;
                    text-align: center;
                }

                    .input-group input:focus {
                        border-color: var(--cyber-cyan);
                        box-shadow: 0 0 10px rgba(0, 180, 216, 0.2);
                    }

            .btn-submit {
                width: 100%;
                padding: 16px;
                background-color: var(--cyber-cyan);
                color: var(--bg-deep-blue);
                border: none;
                border-radius: 12px;
                font-size: 18px;
                font-weight: bold;
                cursor: pointer;
                transition: 0.3s;
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 10px;
            }

                .btn-submit:hover {
                    background-color: #48CAE4;
                    box-shadow: 0 5px 15px rgba(0, 180, 216, 0.4);
                }

            .security-note {
                text-align: center;
                margin-top: 20px;
                font-size: 13px;
                color: rgba(224, 251, 252, 0.6);
            }

            .error-message {
                color: var(--error-red);
                font-weight: bold;
                text-align: center;
                margin-bottom: 15px;
                font-size: 14px;
            }
    </style>
</head>
<body>

    <header>
        <div class="logo">
           
            <i class="fa-solid fa-shield-halved"></i> صِـوان | SIWAN
            
        </div>
        <div class="nav-tabs">
            <button class="active" onclick="switchMode('encrypt')">تشفير مستند</button>
            <button onclick="switchMode('decrypt')">فك تشفير</button>
        </div>
    </header>

    <main class="main-container">

        <div class="info-section">
            <div class="feature-badge">
                <i class="fa-solid fa-lock"></i> معيار تشفير عسكري AES-256
            </div>
            <h1 style="margin-top: 20px;">احمِ خصوصية مستنداتك وعقودك بـ <span>سيادة مطلقة</span></h1>
            <p>منصة صِوان تمنحك القدرة على تشفير وثائقك المالية والقانونية بكلمة مرور خاصة بك وحدك. العملية تتم لحظياً داخل متصفحك دون رفع أو حفظ أي ملف في سيرفراتنا لتستمتع بأمان بنسبة 100%.</p>
        </div>

        <div class="vault-card">
            <div class="error-message" asp-validation-summary="All"></div>

            <form id="vaultForm" method="post" enctype="multipart/form-data" asp-page-handler="Encrypt" onsubmit="return validateForm(event)">

                <div class="drop-zone" onclick="document.getElementById('fileInput').click()">
                    <i class="fa-solid fa-file-shield" id="uploadIcon"></i>
                    <p id="uploadText">اسحبي وأفلتي العقد أو المستند هنا، أو اضغطي للاختيار</p>
                    <input type="file" id="fileInput" name="uploadedFile" required style="display: none;" onchange="updateFileName()">
                </div>

                <div class="input-group">
                    <label id="passLabel" for="password">أنشئي مفتاح الأمان (كلمة المرور):</label>
                    <input type="password" id="password" name="password" required placeholder="••••••••">
                </div>

                <div class="input-group" id="confirmGroup">
                    <label id="confirmLabel" for="confirmPassword">أعيدي كتابة مفتاح الأمان للتأكيد:</label>
                    <input type="password" id="confirmPassword" placeholder="••••••••">
                </div>

                <button type="submit" class="btn-submit" id="mainBtn">
                    <i class="fa-solid fa-key"></i> <span id="btnText">صِوان وحماية المستند</span>
                </button>

                <p class="security-note">
                    <i class="fa-solid fa-user-secret"></i> هندسة معرفة صفرية: لا نطلب إيميلك، ولا نخزن ملفاتك.
                </p>
            </form>
        </div>

    </main>

    <script>
            let currentMode = 'encrypt';

            // دالة التبديل الذكي وتغيير مسار الإرسال (Handler) ديناميكياً
            function switchMode(mode) {
                currentMode = mode;
                const buttons = document.querySelectorAll('.nav-tabs button');
                buttons[0].classList.toggle('active', mode === 'encrypt');
                buttons[1].classList.toggle('active', mode === 'decrypt');

                const confirmGroup = document.getElementById('confirmGroup');
                const confirmInput = document.getElementById('confirmPassword');
                const passLabel = document.getElementById('passLabel');
                const btnText = document.getElementById('btnText');
                const vaultForm = document.getElementById('vaultForm');
                const uploadIcon = document.getElementById('uploadIcon');
                const uploadText = document.getElementById('uploadText');

                if (mode === 'encrypt') {
                    confirmGroup.style.display = 'block';
                    confirmInput.required = true;
                    passLabel.innerText = 'أنشئي مفتاح الأمان (كلمة المرور):';
                    btnText.innerText = 'صِوان وحماية المستند';
                    uploadIcon.className = "fa-solid fa-file-shield";
                    uploadText.innerText = "اسحبي وأفلتي العقد أو المستند هنا، أو اضغطي للاختيار";

                    // تحويل الإرسال لدالة التشفير
                    vaultForm.setAttribute('action', '/Index?handler=Encrypt');
                } else {
                    confirmGroup.style.display = 'none';
                    confirmInput.required = false;
                    passLabel.innerText = 'أدخلي مفتاح الأمان لفك التشفير:';
                    btnText.innerText = 'فك تشفير المستند واستعادته';
                    uploadIcon.className = "fa-solid fa-file-signature";
                    uploadText.innerText = "اختر ملف الصِوان المشفر الحامل لامتداد (.siwan)";

                    // تحويل الإرسال لدالة فك التشفير
                    vaultForm.setAttribute('action', '/Index?handler=Decrypt');
                }
            }

            function updateFileName() {
                const fileInput = document.getElementById('fileInput');
                const uploadText = document.getElementById('uploadText');
                if(fileInput.files.length > 0) {
                    uploadText.innerText = "📁 الملف الجاهز: " + fileInput.files[0].name;
                    uploadText.style.color = "#00B4D8";
                }
            }

            // فحص تطابق كلمة المرور عند التشفير فقط ودون فرملة إرسال الفورم الفعلي
            function validateForm(event) {
                const pass = document.getElementById('password').value;
                const confirmPass = document.getElementById('confirmPassword').value;

                if (currentMode === 'encrypt' && pass !== confirmPass) {
                    alert('⚠️ عذراً: مفتاح الأمان غير متطابق! يرجى التأكد وإعادة الكتابة لحماية ملفك.');
                    return false;
                }
                return true;
            }
    </script>
</body>
</html>